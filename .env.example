# ─────────────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` and fill in your Adyen TEST values.
#  NEVER commit `.env`. .gitignore blocks it. Use TEST keys until you go live.
#  All values come from the Adyen Customer Area (test): https://ca-test.adyen.com
# ─────────────────────────────────────────────────────────────────────────────

# ── Adyen — the card acquirer (Visa / Mastercard / Amex / Discover) ──
# Developers → API credentials → your ws user → API key
ADYEN_API_KEY=YOUR_ADYEN_API_KEY
# Your merchant account name (e.g. YourCompanyECOM)
ADYEN_MERCHANT_ACCOUNT=YOUR_MERCHANT_ACCOUNT
# Developers → API credentials → Client key (safe to expose to the browser)
ADYEN_CLIENT_KEY=YOUR_CLIENT_KEY
# Developers → Webhooks → your standard webhook → Generate HMAC key
ADYEN_HMAC_KEY=YOUR_ADYEN_HMAC_KEY
# 'test' or 'live'
ADYEN_ENVIRONMENT=test

# ── App ──
PORT=4242
DOMAIN=http://localhost:4242
CURRENCY=USD
COUNTRY=US

# ── Settlement / treasury (OPTIONAL — final step, once you have the account) ──
# Adyen pays out to a bank account. That bank account can be the US account
# details Wise Business or Revolut Business issue you. Used by the treasury stub.
WISE_API_TOKEN=
WISE_PROFILE_ID=
